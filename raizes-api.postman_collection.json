{
  "info": {
    "name": "Raízes do Nordeste API",
    "description": "Coleção completa de testes da API REST do sistema Raízes do Nordeste. Organize a execução na ordem: Auth → Pedidos → Pagamentos → Erros.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "T01 - Login válido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "email", "value": "gerente@raizes.com", "type": "text" },
              { "key": "senha", "value": "Senha@123", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "T01 - Positivo. Login com credenciais válidas. JWT retornado como cookie httpOnly (não no body)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"nome\": \"Carlos Gerente\",\n  \"email\": \"gerente@raizes.com\",\n  \"cargo\": \"GERENTE\",\n  \"dataExpiracao\": \"2026-05-29T10:32:14Z\"\n}"
            }
          ]
        },
        {
          "name": "T02 - Login com credenciais inválidas",
          "request": {
            "method": "POST",
            "header": [
              { "key": "email", "value": "gerente@raizes.com", "type": "text" },
              { "key": "senha", "value": "senhaErrada", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "T02 - Negativo. Credenciais inválidas devem retornar 401."
          },
          "response": [
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"UNAUTHORIZED\",\n  \"message\": \"E-mail ou senha inválidos.\",\n  \"details\": [],\n  \"timestamp\": \"2026-05-15T09:28:55Z\",\n  \"path\": \"/api/auth/login\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Encerra a sessão removendo o cookie JWT."
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Alterar Senha",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "senhaAtual", "value": "Senha@123", "type": "text" },
              { "key": "senhaNova", "value": "NovaSenha@456", "type": "text" },
              { "key": "senhaNovaValidate", "value": "NovaSenha@456", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/alterar-senha",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "alterar-senha"]
            },
            "description": "Altera senha do usuário autenticado. Credenciais enviadas via headers. Requer cookie JWT."
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Registro de Usuário",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Ana Atendente\",\n  \"email\": \"ana@raizes.com\",\n  \"senha\": \"Senha@123\",\n  \"cargo\": \"ATENDENTE\",\n  \"unidadeId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/registro",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "registro"]
            },
            "description": "Cadastra novo funcionário. Requer cargo GERENTE."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 5,\n  \"nome\": \"Ana Atendente\",\n  \"email\": \"ana@raizes.com\",\n  \"cargo\": \"ATENDENTE\",\n  \"unidadeId\": 1\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "T03 - Criar pedido com estoque suficiente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": 10,\n  \"unidadeId\": 1,\n  \"canalPedido\": \"BALCAO\",\n  \"itens\": [\n    { \"produtoId\": 3, \"quantidade\": 2 },\n    { \"produtoId\": 7, \"quantidade\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"]
            },
            "description": "T03 - Positivo. Cria pedido com estoque disponível. Deve retornar 201 com status AGUARDANDO_PAGAMENTO."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"pedidoId\": 42,\n  \"status\": \"AGUARDANDO_PAGAMENTO\",\n  \"total\": 89.70,\n  \"itens\": [\n    { \"produtoId\": 3, \"quantidade\": 2, \"precoUnitario\": 32.90 },\n    { \"produtoId\": 7, \"quantidade\": 1, \"precoUnitario\": 23.90 }\n  ],\n  \"createdAt\": \"2026-05-19T15:33:08Z\"\n}"
            }
          ]
        },
        {
          "name": "T04 - Criar pedido com canalPedido ausente (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": 10,\n  \"unidadeId\": 1,\n  \"itens\": [\n    { \"produtoId\": 3, \"quantidade\": 2 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"]
            },
            "description": "T04 - Negativo. Campo obrigatório canalPedido ausente. Deve retornar 400."
          },
          "response": [
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"BAD_REQUEST\",\n  \"message\": \"Campo obrigatório ausente.\",\n  \"details\": [\n    { \"field\": \"canalPedido\", \"issue\": \"Campo obrigatório não informado.\" }\n  ],\n  \"timestamp\": \"2026-05-19T15:33:08Z\",\n  \"path\": \"/api/pedidos\"\n}"
            }
          ]
        },
        {
          "name": "T05 - Criar pedido com produto inexistente (404)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": 10,\n  \"unidadeId\": 1,\n  \"canalPedido\": \"APP\",\n  \"itens\": [\n    { \"produtoId\": 9999, \"quantidade\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"]
            },
            "description": "T05 - Negativo. Produto com ID inexistente. Deve retornar 404."
          },
          "response": [
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"NOT_FOUND\",\n  \"message\": \"Produto não encontrado.\",\n  \"details\": [],\n  \"timestamp\": \"2026-05-19T15:33:08Z\",\n  \"path\": \"/api/pedidos\"\n}"
            }
          ]
        },
        {
          "name": "T06 - Criar pedido com estoque insuficiente (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": 10,\n  \"unidadeId\": 1,\n  \"canalPedido\": \"TOTEM\",\n  \"itens\": [\n    { \"produtoId\": 3, \"quantidade\": 9999 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"]
            },
            "description": "T06 - Negativo. Quantidade maior que estoque disponível. Deve retornar 409."
          },
          "response": [
            {
              "name": "409 Conflict",
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"CONFLICT\",\n  \"message\": \"Estoque insuficiente para o produto 3.\",\n  \"details\": [],\n  \"timestamp\": \"2026-05-19T15:33:08Z\",\n  \"path\": \"/api/pedidos\"\n}"
            }
          ]
        },
        {
          "name": "Listar Pedidos por unidade e status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pedidos?unidadeId=1&status=EM_PREPARACAO",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"],
              "query": [
                { "key": "unidadeId", "value": "1" },
                { "key": "clienteId", "value": "", "disabled": true },
                { "key": "canalPedido", "value": "", "disabled": true },
                { "key": "status", "value": "EM_PREPARACAO" }
              ]
            },
            "description": "Positivo. Lista pedidos com filtros. Ao menos um filtro obrigatório."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"pedidoId\": 42,\n    \"status\": \"EM_PREPARACAO\",\n    \"total\": 89.70,\n    \"itens\": [\n      { \"produtoId\": 3, \"quantidade\": 2, \"precoUnitario\": 32.90 }\n    ],\n    \"createdAt\": \"2026-05-19T15:33:08Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Listar Pedidos por canal (canalPedido)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pedidos?canalPedido=TOTEM",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"],
              "query": [
                { "key": "canalPedido", "value": "TOTEM" }
              ]
            },
            "description": "Positivo. Filtra pedidos pelo canal de atendimento (multicanalidade)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"pedidoId\": 43,\n    \"status\": \"AGUARDANDO_PAGAMENTO\",\n    \"total\": 45.90,\n    \"itens\": [\n      { \"produtoId\": 5, \"quantidade\": 1, \"precoUnitario\": 45.90 }\n    ],\n    \"createdAt\": \"2026-05-21T11:02:17Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Buscar Pedido por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pedidos/42",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos", "42"]
            },
            "description": "Positivo. Retorna detalhes de um pedido específico."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"pedidoId\": 42,\n  \"status\": \"AGUARDANDO_PAGAMENTO\",\n  \"total\": 89.70,\n  \"itens\": [\n    { \"produtoId\": 3, \"quantidade\": 2, \"precoUnitario\": 32.90 },\n    { \"produtoId\": 7, \"quantidade\": 1, \"precoUnitario\": 23.90 }\n  ],\n  \"createdAt\": \"2026-05-19T15:33:08Z\"\n}"
            }
          ]
        },
        {
          "name": "T07 - Atualizar status do pedido (GERENTE)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_PREPARACAO\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos/42/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos", "42", "status"]
            },
            "description": "T07 - Positivo. Gerente atualiza status do pedido."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"pedidoId\": 42,\n  \"status\": \"EM_PREPARACAO\",\n  \"total\": 89.70,\n  \"itens\": [\n    { \"produtoId\": 3, \"quantidade\": 2, \"precoUnitario\": 32.90 }\n  ],\n  \"createdAt\": \"2026-05-19T15:33:08Z\"\n}"
            }
          ]
        },
        {
          "name": "Cancelar Pedido",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pedidos/42/cancelar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos", "42", "cancelar"]
            },
            "description": "Positivo. Cancela um pedido e restaura estoque."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"pedidoId\": 42,\n  \"status\": \"CANCELADO\",\n  \"total\": 89.70,\n  \"itens\": [\n    { \"produtoId\": 3, \"quantidade\": 2, \"precoUnitario\": 32.90 }\n  ],\n  \"createdAt\": \"2026-05-19T15:33:08Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Pagamentos",
      "item": [
        {
          "name": "T08 - Pagamento mock aprovado",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"formaPagamento\": \"PIX\",\n  \"simularFalha\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pagamentos/42",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pagamentos", "42"]
            },
            "description": "T08 - Positivo. Pagamento aprovado. pedidoId no path. Status do pedido deve avançar para EM_PREPARACAO."
          },
          "response": [
            {
              "name": "200 Aprovado",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"pagamentoId\": 18,\n  \"pedidoId\": 42,\n  \"formaPagamento\": \"PIX\",\n  \"statusPagamento\": \"APROVADO\",\n  \"statusPedido\": \"EM_PREPARACAO\",\n  \"valor\": 89.70\n}"
            }
          ]
        },
        {
          "name": "T09 - Pagamento mock recusado",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"formaPagamento\": \"CREDITO\",\n  \"simularFalha\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pagamentos/42",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pagamentos", "42"]
            },
            "description": "T09 - Negativo (regra de negócio). Pagamento recusado. pedidoId no path. Status permanece AGUARDANDO_PAGAMENTO e response inclui mensagem explicativa."
          },
          "response": [
            {
              "name": "200 Recusado",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"pagamentoId\": 19,\n  \"pedidoId\": 42,\n  \"formaPagamento\": \"CREDITO\",\n  \"statusPagamento\": \"RECUSADO\",\n  \"statusPedido\": \"AGUARDANDO_PAGAMENTO\",\n  \"valor\": 89.70,\n  \"mensagem\": \"Pagamento recusado pela operadora. Tente outro meio de pagamento.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Erros",
      "item": [
        {
          "name": "T10 - Requisição sem cookie JWT (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pedidos?unidadeId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"],
              "query": [{ "key": "unidadeId", "value": "1" }]
            },
            "description": "T10 - Negativo. Acesso a endpoint protegido sem token JWT. Deve retornar 401."
          },
          "response": [
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"UNAUTHORIZED\",\n  \"message\": \"Token de autenticação ausente ou inválido.\",\n  \"details\": [],\n  \"timestamp\": \"2026-05-24T10:15:52Z\",\n  \"path\": \"/api/pedidos\"\n}"
            }
          ]
        },
        {
          "name": "T11 - Acesso com cargo sem permissão (403)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ENTREGUE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos/42/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos", "42", "status"]
            },
            "description": "T11 - Negativo. Cargo ATENDENTE tentando transição de status não permitida. Deve retornar 403. (Faça login como ATENDENTE antes de executar.)"
          },
          "response": [
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"FORBIDDEN\",\n  \"message\": \"Cargo não autorizado para esta transição de status.\",\n  \"details\": [],\n  \"timestamp\": \"2026-05-22T14:28:39Z\",\n  \"path\": \"/api/pedidos/42/status\"\n}"
            }
          ]
        },
        {
          "name": "T12 - Listar pedidos sem filtros (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"]
            },
            "description": "T12 - Negativo. Listagem sem nenhum filtro. Deve retornar 400."
          },
          "response": [
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"BAD_REQUEST\",\n  \"message\": \"Informe ao menos um filtro para listar pedidos.\",\n  \"details\": [],\n  \"timestamp\": \"2026-05-21T11:02:17Z\",\n  \"path\": \"/api/pedidos\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
